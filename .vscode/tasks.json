{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake --preset windows-vs2022",
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "CMake: Build Debug",
            "type": "shell",
            "command": "cmake --build build/vs2022 --config Debug",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile",
            "dependsOn": "CMake: Configure"
        },
        {
            "label": "CMake: Build Release",
            "type": "shell",
            "command": "cmake --build build/vs2022 --config Release",
            "group": "build",
            "problemMatcher": "$msCompile",
            "dependsOn": "CMake: Configure"
        }
    ]
}
